{
  "name": "apparaatti",
  "version": "0.0.1",
  "description": "Platform for recmmending the correct courses based on user feedback",
  "type": "module",
  "scripts": {
    "start": "docker compose up",
    "prod": "NODE_ENV=production node --no-warnings --experimental-strip-types src/server/index.ts",
    "dev": "NODE_ENV=development concurrently \"nodemon --verbose --ignore '*cypress*' --exec node --no-warnings --experimental-strip-types src/server/index.ts\" \"vite\"",
    "e2e": "sh ./scripts/run-cypress.sh",
    "e2e:up": "docker compose -f compose.e2e.yaml up",
    "e2e:down": "docker compose -f compose.e2e.yaml down",
    "tsc": "tsc --build --noEmit",
    "test": "vitest",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:all": "eslint 'src/**/*.{ts,tsx}' && prettier 'src/**/*.{ts,tsx,json,css,md}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "lint:fix:all": "eslint 'src/**/*.{ts,tsx}' --fix && prettier --write 'src/**/*.{ts,tsx,json,css,md}'",
    "translations": "node scripts/analyzeTranslations.js",
    "format": "prettier --write '*.{ts,json,css,md}'",
    "build": "vite build",
    "prepare": "husky"
  },
  "prettier": {
    "semi": false,
    "arrowParens": "avoid",
    "singleQuote": true,
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "jsxSingleQuote": false,
    "trailingComma": "es5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/express-session": "1.19.0",
    "@types/node-cron": "3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/passport": "^1.0.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cypress": "^14.5.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "15.5.2",
    "minimist": "^1.2.8",
    "nodemon": "^3.1.14",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "nodemonConfig": {
    "ignore": [
      "e2e",
      "cypress"
    ],
    "watch": [
      "src"
    ],
    "ext": "*.js,*.ts,*.json"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^9.0.4",
    "@tanstack/react-query": "^5.90.21",
    "@uh-design-system/component-library": "1.5.2",
    "axios": "1.13.6",
    "bindings": "^1.5.0",
    "connect-redis": "^8.1.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "i18next": "^25.8.18",
    "ioredis": "^5.10.0",
    "node-cron": "^3.0.3",
    "openid-client": "^5.7.1",
    "papaparse": "^5.5.3",
    "passport": "^0.7.0",
    "passport-oauth": "^1.0.0",
    "passport-oauth2": "^1.8.0",
    "passport-openidconnect": "^0.1.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.7.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "redis": "^4.7.1",
    "remark-gfm": "^4.0.1",
    "sequelize": "^6.37.8",
    "umzug": "^3.8.2",
    "winston": "^3.19.0",
    "winston-gelf-transporter": "^1.0.2",
    "winston-loki": "^6.1.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}
